<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DRPS_PHCA.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DRPS_PHCA"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="DRPS PHCA">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid x:Name="TitleBarDragArea" Grid.Row="0" Height="32" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="12,0,0,0"
                        IsHitTestVisible="False">
                <Image Source="Assets/Square44x44Logo.scale-100.png" Width="16" Height="16" />
                <TextBlock Text="DRPS PHCA"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- Content area -->
        <Grid Grid.Row="1">

            <!-- Home view -->
            <ScrollViewer x:Name="HomeView" VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="24,72,24,24" Spacing="32">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Latest Newsletter" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Border x:Name="NewsletterContainer"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" MinHeight="180" />
                    </StackPanel>
                    <StackPanel Spacing="12">
                        <TextBlock Text="Latest Blog Posts" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid x:Name="BlogGrid" ColumnSpacing="12" RowSpacing="12" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Blog view -->
            <ScrollViewer x:Name="BlogView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="24,72,24,24" Spacing="16">
                    <TextBlock Text="Blog" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <Grid x:Name="BlogViewGrid" ColumnSpacing="12" RowSpacing="12" />
                    <Button x:Name="BlogLoadMoreButton" Content="Load More"
                            Click="BlogLoadMore_Click"
                            HorizontalAlignment="Center"
                            Padding="24,10" CornerRadius="8" Margin="0,8,0,8" />
                </StackPanel>
            </ScrollViewer>

            <!-- Newsletter view -->
            <ScrollViewer x:Name="NewsletterView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="24,72,24,24" Spacing="16">
                    <TextBlock Text="Newsletter" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <Grid x:Name="NewsletterViewGrid" ColumnSpacing="12" RowSpacing="12" />
                </StackPanel>
            </ScrollViewer>

            <!-- Article toolbar (hidden until reading a post) -->
            <!-- Article toolbar: floating small Back button only -->
            <Border x:Name="ArticleToolbar"
                    VerticalAlignment="Top"
                    Visibility="Collapsed"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Margin="16,8,0,0"
                    Canvas.ZIndex="5"
                    HorizontalAlignment="Left">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Background="Transparent"
                        Padding="0">
                    <Button x:Name="BackButton" Click="BackButton_Click" Background="#128FF1" Foreground="White" BorderThickness="0" Padding="10,6" MinWidth="0"
                            PointerEntered="BackButton_PointerEntered" PointerExited="BackButton_PointerExited">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72B;" FontSize="12" Foreground="White" />
                            <TextBlock Text="Back" Foreground="White" />
                        </StackPanel>
                    </Button>
                </Border>
            </Border>

            <!-- WebView2 for article reading -->
            <WebView2 x:Name="ArticleWebView"
                      Visibility="Collapsed"
                      Canvas.ZIndex="4"
                      CoreWebView2Initialized="ArticleWebView_CoreWebView2Initialized" />

            <!-- Floating nav bar — overlay, not in layout flow -->
            <Border x:Name="NavBar"
                    VerticalAlignment="Top"
                    Margin="16,8,16,0"
                    Canvas.ZIndex="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" Source="Assets/Asset-Logo-DRPSPHCAdotCom.png"
                           Height="32" VerticalAlignment="Center" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">

                        <!-- Home button — custom template so Background binding is not overridden by PointerOver state -->
                        <Button x:Name="NavHomeButton" Click="NavHome_Click" BorderThickness="0" Padding="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="8" Padding="12,6">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Viewbox Width="18" Height="18">
                                    <PathIcon x:Name="NavHomeIcon"
                                              Data="M10,20v-6h4v6h5v-8h3L12,3 2,12h3v8z" />
                                </Viewbox>
                                <TextBlock x:Name="NavHomeText" Text="Home"
                                           FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Blog button -->
                        <Button x:Name="NavBlogButton" Click="NavBlog_Click" BorderThickness="0" Padding="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="8" Padding="12,6">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Viewbox Width="18" Height="18">
                                    <PathIcon x:Name="NavBlogIcon"
                                              Data="M19,3H5C3.9,3 3,3.9 3,5v14c0,1.1 0.9,2 2,2h14c1.1,0 2,-0.9 2,-2V5C21,3.9 20.1,3 19,3zM19,19H5V5h14V19z M7,7h10v2H7V7z M7,11h10v2H7V11z M7,15h7v2H7V15z" />
                                </Viewbox>
                                <TextBlock x:Name="NavBlogText" Text="Blog"
                                           FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Newsletter button -->
                        <Button x:Name="NavNewsletterButton" Click="NavNewsletter_Click" BorderThickness="0" Padding="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="8" Padding="12,6">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Viewbox Width="18" Height="18">
                                    <PathIcon x:Name="NavNewsletterIcon"
                                              Data="M20,4H4C2.9,4 2,4.9 2,6v12c0,1.1 0.9,2 2,2h16c1.1,0 2,-0.9 2,-2V6C22,4.9 21.1,4 20,4zM20,18H4V8l8,5l8,-5V18zM12,11L4,6h16L12,11z" />
                                </Viewbox>
                                <TextBlock x:Name="NavNewsletterText" Text="Newsletter"
                                           FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock x:Name="VersionText"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="&#169; 2026 DRPS PHCA"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                    <HyperlinkButton Content="Terms of Use" Click="TermsButton_Click" FontSize="12" Padding="4,0" />
                    <TextBlock Text="|" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <HyperlinkButton Content="Privacy Policy" Click="PrivacyButton_Click" FontSize="12" Padding="4,0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
